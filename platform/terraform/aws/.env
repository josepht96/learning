# LocalStack Configuration
# Leave SERVICES empty to enable all AWS services, or specify comma-separated list
# Examples: s3,dynamodb,lambda,ec2,ecs,rds,sqs,sns
SERVICES=

# Enable debug mode (0 = off, 1 = on)
DEBUG=0

# Lambda executor (docker, docker-reuse, local)
LAMBDA_EXECUTOR=docker

# Persistence enabled by default (1 = on, 0 = off)
PERSISTENCE=1

# Directory for persistent data (relative to docker-compose.yml)
LOCALSTACK_VOLUME_DIR=./localstack-data
